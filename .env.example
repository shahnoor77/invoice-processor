# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invoice_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Use a long random string in production
JWT_SECRET_KEY=change-this-to-a-long-random-secret

# ── OpenAI (set to "fake-key" if not using OpenAI directly) ──────────────────
OPENAI_API_KEY=fake-key

# ── Ollama (self-hosted model) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://your-ollama-vm-ip:11434
OLLAMA_API_BASE=http://your-ollama-vm-ip:11434

# ── Active model — change to switch providers ─────────────────────────────────
# Ollama:   MODEL=ollama/qwen3.5:9b
# Groq:     MODEL=groq/llama-3.3-70b-versatile
# OpenAI:   MODEL=openai/gpt-4o-mini
# Gemini:   MODEL=gemini/gemini-1.5-flash
MODEL=ollama/qwen3.5:9b

# Required if using Groq, OpenAI, or Gemini
MODEL_API_KEY=your_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Email (optional — for SMTP notifications) ─────────────────────────────────
SMTP_USER=
SMTP_PASSWORD=

# ── Google Sheets integration (optional) ─────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here
