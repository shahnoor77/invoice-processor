# ── Copy this to .env and fill in your values ────────────────────────────────
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_this_password

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_secret

# ── OpenAI (set to "fake-key" if not using OpenAI directly) ──────────────────
OPENAI_API_KEY=fake-key

# ── Ollama (self-hosted model server) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://your-ollama-vm-ip:11434
OLLAMA_API_BASE=http://your-ollama-vm-ip:11434

# ── Active model ──────────────────────────────────────────────────────────────
# Ollama:   MODEL=ollama/qwen3.5:9b
# Groq:     MODEL=groq/llama-3.3-70b-versatile
# OpenAI:   MODEL=openai/gpt-4o-mini
# Gemini:   MODEL=gemini/gemini-1.5-flash
MODEL=ollama/qwen3.5:9b

# Required if using Groq, OpenAI, or Gemini
MODEL_API_KEY=
GROQ_API_KEY=

# ── Email / SMTP (optional) ───────────────────────────────────────────────────
SMTP_USER=
SMTP_PASSWORD=

# ── Google Sheets (optional) ──────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_SHEET_ID=


# ── Email password encryption ─────────────────────────────────────────────────
# Change these in production — used to encrypt stored email passwords
EMAIL_ENCRYPTION_KEY=set
EMAIL_ENCRYPTION_SALT=set