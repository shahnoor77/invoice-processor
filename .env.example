# Copy this file to .env and fill in your values
# cp .env.example .env

# Required — set to "fake-key" if not using OpenAI
OPENAI_API_KEY=fake-key

# JWT secret for API auth — use a long random string in production
JWT_SECRET_KEY=change-this-to-a-long-random-secret

# Ollama VM (self-hosted model)
OLLAMA_BASE_URL=http://your-ollama-vm-ip:11434
OLLAMA_API_BASE=http://your-ollama-vm-ip:11434

# Active model — change this to switch providers
# Ollama (offline):  MODEL=ollama/qwen3.5:9b
# Ollama (fast):     MODEL=ollama/llama3.1:8b
# Groq (free):       MODEL=groq/llama-3.3-70b-versatile
# OpenAI:            MODEL=openai/gpt-4o-mini
# Gemini (free):     MODEL=gemini/gemini-1.5-flash
MODEL=ollama/qwen3.5:9b

# Required if using Groq, OpenAI, or Gemini
MODEL_API_KEY=your_api_key_here

# Optional — only needed for Groq
GROQ_API_KEY=your_groq_api_key_here

# Google Sheets integration
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here
